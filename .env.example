# Firebase web app configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Cloud OAuth client with application type "Desktop app".
# Required only for Google sign-in in the macOS/Windows/Linux app.
VITE_GOOGLE_DESKTOP_CLIENT_ID=your_desktop_oauth_client_id.apps.googleusercontent.com

# Local API during development; replace with the production HTTPS API for deploys.
VITE_API_URL=http://localhost:3001
